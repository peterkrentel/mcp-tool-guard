#!/usr/bin/env bash
set -euo pipefail

# Enforce staged changelog updates for each local commit.
# Set SKIP_CHANGELOG_HOOK=1 to bypass locally (CI still enforces policy).
if [[ "${SKIP_CHANGELOG_HOOK:-}" == "1" ]]; then
  exit 0
fi

if git diff --cached --name-only | grep -qx 'CHANGELOG.md'; then
  exit 0
fi

echo "ERROR: This commit must include CHANGELOG.md under [Unreleased]." >&2
echo "Tip: update CHANGELOG.md and re-stage it before commit." >&2
echo "Temporary bypass: SKIP_CHANGELOG_HOOK=1 git commit ..." >&2
exit 1
