# Guard proxy + agent gateway (local: export before `make proxy` or add to scripts/dev.env)
# Copy to scripts/dev.env for local dev — see scripts/dev.env.example for MCP_JWT_*.

# --- Existing guard proxy JWT trust (guest PEM + Auth0) ---
# MCP_GUARD_PUBLIC_KEY_PEM=
# MCP_JWT_ISSUER=https://YOUR_TENANT.us.auth0.com/
# MCP_JWT_AUDIENCE=https://mcp-tool-guard
# MCP_JWT_JWKS_URL=
# MCP_CORS_ORIGINS=http://localhost:5173,https://mcp-tool-guard-ui.vercel.app
# MCP_PROXY_CONFIG=config.prod.yaml
# MCP_PROXY_DEFAULT_SERVER=flight
# MCP_PROXY_PORT=8787
# MCP_GATEWAY_ADMIN_AUTH=false   # optional: disable gateway:admin on control plane (local only)

# --- Agent gateway: Auth0 M2M lifecycle + token vending ---
# Create a Machine-to-Machine app in Auth0 with Management API access (create/delete clients, client grants).
AUTH0_DOMAIN=YOUR_TENANT.us.auth0.com
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=
AUTH0_AUDIENCE=https://mcp-tool-guard

# --- GitHub MCP (Track 2) — PAT for upstream only; never exposed to clients ---
# GITHUB_MCP_TOKEN=ghp_...
# VITE_PROXY_BASE_URL=          # default: same origin (Vite dev proxies to :8787)
# VITE_GEMINI_API_KEY=
# VITE_GROQ_API_KEY=
# VITE_MISTRAL_API_KEY=
# VITE_AUTH0_DOMAIN=
# VITE_AUTH0_CLIENT_ID=
# VITE_AUTH0_AUDIENCE=
