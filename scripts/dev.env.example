# Copy to scripts/dev.env (gitignored) — loaded by `make dev` for flight + proxy.
# UI Auth0 vars still go in ui/.env.local (VITE_AUTH0_*).
#
# cp scripts/dev.env.example scripts/dev.env

# --- Auth0 JWT trust (flight + guard proxy) ---
# export MCP_JWT_ISSUER=https://YOUR_TENANT.us.auth0.com/
# export MCP_JWT_AUDIENCE=https://mcp-tool-guard

# --- Agent gateway: Auth0 M2M lifecycle + token vending (proxy only) ---
# Create a Machine-to-Machine app in Auth0 with Management API access:
#   create:clients, delete:clients, create:client_grants, delete:client_grants, read:clients
# export AUTH0_DOMAIN=YOUR_TENANT.us.auth0.com
# export AUTH0_MGMT_CLIENT_ID=
# export AUTH0_MGMT_CLIENT_SECRET=
# export AUTH0_AUDIENCE=https://mcp-tool-guard

# Optional ports (defaults: flight 8000, proxy 8787)
# export FLIGHT_PORT=8000
# export PROXY_PORT=8787
