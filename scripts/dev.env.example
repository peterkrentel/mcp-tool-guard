# Copy to scripts/dev.env (gitignored) — loaded by `make dev` for flight + proxy.
# UI Auth0 vars still go in ui/.env.local (VITE_AUTH0_*).
#
# cp scripts/dev.env.example scripts/dev.env

# --- Auth0 JWT trust (flight + guard proxy) ---
# export MCP_JWT_ISSUER=https://YOUR_TENANT.us.auth0.com/
# export MCP_JWT_AUDIENCE=https://mcp-tool-guard
# Optional: disable immediate M2M revocation checks in local no-KV dev.
# export MCP_M2M_REVOCATION=false

# --- Agent gateway: Auth0 M2M lifecycle + token vending (proxy only) ---
# Create a Machine-to-Machine app in Auth0 with Management API access:
#   create:clients, delete:clients, create:client_grants, delete:client_grants, read:clients
# export AUTH0_DOMAIN=YOUR_TENANT.us.auth0.com
# export AUTH0_MGMT_CLIENT_ID=
# export AUTH0_MGMT_CLIENT_SECRET=
# export AUTH0_AUDIENCE=https://mcp-tool-guard

# --- GitHub MCP upstream (proxy only — never expose to UI) ---
# Fine-grained PAT with repo read (and write for allow smoke tests).
# export GITHUB_MCP_TOKEN=ghp_...

# --- scripts/smoke-deployed.sh: standing gateway:admin test user ---
# AUTH0_MGMT_CLIENT_ID above isn't scoped for create:users, so this can't be
# provisioned automatically. Create one real Auth0 user yourself once, in the
# Username-Password-Authentication connection, and grant it the gateway:admin
# permission on the mcp-tool-guard API via its Permissions tab in the Auth0
# dashboard. The smoke script authenticates as this user by driving the real
# /agents.html login (scripts/auth0-headless-login.mjs, Playwright) — ROPG
# against this account's client was tried and consistently rejected, so this
# replays the actual Authorization Code flow instead. Never creates or
# deletes this account itself.
# export SMOKE_ADMIN_EMAIL=
# export SMOKE_ADMIN_PASSWORD=

# Optional ports (defaults: flight 8000, proxy 8787)
# export FLIGHT_PORT=8000
# export PROXY_PORT=8787

# --- Claude Code MCP agent (scripts/claude-mcp-token-helper.sh, BL-037) ---
# repo:read-only local M2M agent for connecting Claude Code to the github-guarded
# server. Create via POST /agents (see docs/superpowers/plans/2026-07-19-bl-037-*),
# then paste the returned clientId/clientSecret here (shown once, not retrievable later).
# export MCP_AGENT_CLIENT_ID=
# export MCP_AGENT_CLIENT_SECRET=
