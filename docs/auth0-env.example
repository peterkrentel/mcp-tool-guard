# Auth0 / JWKS env template (0.3)
# Copy to ui/.env.local for local dev; set in Vercel project settings for prod.
# See docs/auth0-setup.md

# --- UI (Vite) ---
VITE_AUTH0_DOMAIN=YOUR_TENANT.us.auth0.com
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://mcp-tool-guard
VITE_MCP_URL=http://localhost:5173/mcp

# --- Flight server (local or Vercel) ---
# MCP_JWT_ISSUER=https://YOUR_TENANT.us.auth0.com/
# MCP_JWT_AUDIENCE=https://mcp-tool-guard
# MCP_JWT_JWKS_URL=https://YOUR_TENANT.us.auth0.com/.well-known/jwks.json

# PEM fallback (0.2.x / CI) until JWKS mode ships:
# MCP_GUARD_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----..."

# VITE_ENABLE_GUEST_DEMO=true
