# Auth0 / JWKS env template (0.3)
# See docs/auth0-setup.md — UI vs flight env are separate.

# --- UI only: copy to ui/.env.local (gitignored) ---
# Vite reads VITE_* at startup. Restart `make ui` after changes.
VITE_AUTH0_DOMAIN=YOUR_TENANT.us.auth0.com
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://mcp-tool-guard
VITE_MCP_URL=http://localhost:5173/mcp

# Agent gateway (prod only — local dev uses Vite proxy, leave unset)
# VITE_PROXY_BASE_URL=https://mcp-tool-guard-proxy.onrender.com

# Optional cloud LLMs on /agents.html (more reliable than WebLLM 1B)
# VITE_GEMINI_API_KEY=
# VITE_GROQ_API_KEY=
# VITE_MISTRAL_API_KEY=

# Guest demo (default on). Set false to require Auth0 login when Auth0 is configured.
# VITE_ENABLE_GUEST_DEMO=true

# --- Flight + guard proxy + agent gateway mgmt (local): scripts/dev.env — NOT ui/.env.local ---
# cp scripts/dev.env.example scripts/dev.env
# Loaded by `make dev` — set MCP_JWT_* and AUTH0_MGMT_* there

# --- Flight server on Vercel ---
# export MCP_JWT_ISSUER=https://YOUR_TENANT.us.auth0.com/
# export MCP_JWT_AUDIENCE=https://mcp-tool-guard
#
# Keep demo PEM for guest tokens AND add JWKS for Auth0 (dual trust):
# MCP_GUARD_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----..."
# MCP_JWT_JWKS_URL=https://YOUR_TENANT.us.auth0.com/.well-known/jwks.json  # optional

# Never disable guard in production:
# MCP_GUARD_ENABLED=true

# Do not put Auth0 user passwords or MCP_JWT_* in ui/.env.local — flight does not read that file.
